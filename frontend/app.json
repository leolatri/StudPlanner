{
  "expo": {
    "name": "StudPlanner",
    "slug": "studplanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/IconApp.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/IconApp.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alena3003.studplanner"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/IconApp.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alena3003.studplanner"
    },
    "web": {
      "favicon": "./assets/IconApp.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
